--- Logic ---

-- Show/Hide Frame with Floating Button
OpenButton.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
end)

local function updateStats()
	local char = player.Character
	if char and char:FindFirstChild("Humanoid") then
		if isEnabled then
			char.Humanoid.WalkSpeed = tonumber(SpeedInput.Text) or 16
			char.Humanoid.JumpPower = tonumber(JumpInput.Text) or 50
		else
			char.Humanoid.WalkSpeed = 16
			char.Humanoid.JumpPower = 50
		end
	end
end

local function toggle()
	isEnabled = not isEnabled
	ToggleBtn.Text = isEnabled and "ON" or "OFF"
	ToggleBtn.BackgroundColor3 = isEnabled and Color3.fromRGB(255, 50, 50) or ThemeRed
    ToggleBtn.TextColor3 = isEnabled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 200, 200)
	updateStats()
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == toggleKey then
		toggle()
	end
end)

ToggleBtn.MouseButton1Click:Connect(toggle)

RunService.RenderStepped:Connect(updateStats)

BindInput.FocusLost:Connect(function()
	local key = BindInput.Text:upper()
	pcall(function()
		toggleKey = Enum.KeyCode[key]
	end)
end)
