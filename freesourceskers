-- Helper function for Input Rows
local function createRow(name, value, pos)
	local Label = Instance.new("TextLabel")
	Label.Size = UDim2.new(0, 100, 0, 40)
	Label.Position = UDim2.new(0, 20, 0, pos)
	Label.BackgroundTransparency = 1
	Label.Text = name
	Label.TextColor3 = Color3.fromRGB(255, 255, 255)
	Label.TextSize = 14
	Label.Font = Enum.Font.GothamBold
	Label.Parent = MainFrame

	local Box = Instance.new("TextBox")
	Box.Size = UDim2.new(0, 90, 0, 40)
	Box.Position = UDim2.new(1, -110, 0, pos)
	Box.BackgroundColor3 = Color3.fromRGB(30, 20, 20)
	Box.Text = tostring(value)
	Box.TextColor3 = ThemeRed
	Box.Font = Enum.Font.GothamBold
	Box.TextSize = 16
	Box.Parent = MainFrame

	local BoxCorner = Instance.new("UICorner")
	BoxCorner.CornerRadius = UDim.new(0, 6)
	BoxCorner.Parent = Box
    
    local BoxStroke = Instance.new("UIStroke")
    BoxStroke.Color = DarkRed
    BoxStroke.Thickness = 1
    BoxStroke.Parent = Box
	
	return Box
end

